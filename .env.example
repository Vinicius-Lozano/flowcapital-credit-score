# =============================================
# FLOWCAPITAL — Environment Variables
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ----- Django -----
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=True

# ----- Belvo Open Finance -----
# Get these from https://dashboard.belvo.com/ (Environment: Sandbox)
BELVO_SECRET_ID=your_secret_id_here
BELVO_SECRET_PASSWORD=your_secret_password_here
BELVO_ENVIRONMENT=sandbox

# ----- AWS -----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET_NAME=
